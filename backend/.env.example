DJANGO_SECRET_KEY=merxylab-local-dev-secret-key-32chars-minimum
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

MYSQL_DATABASE=merxylab
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307

CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

STREAM_LEASE_TTL_SECONDS=180
STREAM_TOKEN_TTL_SECONDS=120
STREAM_SESSION_COOLDOWN_SECONDS=30
MEDIA_ROOT=media

# Optional explicit ffmpeg paths (use when PATH is not picked up)
FFMPEG_BIN=
FFPROBE_BIN=

QUIZ_FAIL_LIMIT_PER_DAY=3
QUIZ_FAIL_COOLDOWN_MINUTES=30
FINAL_EXAM_RETRY_FEE_CREDITS=50

# Production security flags (set to true/secure values in production)
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
USE_X_FORWARDED_PROTO=false

# MongoDB (optional; if set, quiz documents are read/written from Mongo first)
MONGO_URI=
MONGO_DB=merxylab
MONGO_TIMEOUT_MS=2000
